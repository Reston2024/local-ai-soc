# MISP Docker secrets — copy to infra/misp/.env.misp and gitignore it
# Never commit .env.misp

# GMKtec LAN IP (default 192.168.1.22 — check with 'ip addr')
GMKTEC_IP=192.168.1.22

# MariaDB passwords — generate with: openssl rand -hex 24
MISP_DB_ROOT_PASSWORD=CHANGEME_generate_with_openssl_rand_hex_24
MISP_DB_PASSWORD=CHANGEME_generate_with_openssl_rand_hex_24

# MISP admin account (login to web UI after first start)
MISP_ADMIN_EMAIL=admin@misp.local
MISP_ADMIN_PASSWORD=CHANGEME_min12chars

# MISP encryption key — generate with: openssl rand -hex 32
MISP_ENCRYPTION_KEY=CHANGEME_generate_with_openssl_rand_hex_32
