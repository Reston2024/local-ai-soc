# AI-SOC-Brain — Caddyfile
# Caddy handles TLS termination for localhost HTTPS.
# FastAPI runs on host at port 8000.
# Dashboard static files served from /srv/dashboard.

{
    # Auto-HTTPS for localhost (self-signed, trusted by Caddy's own CA)
    local_certs
    # Restrict admin API to localhost only
    admin localhost:2019
    # Log format
    log {
        output stdout
        format json
        level INFO
    }
}

localhost {
    # TLS with local cert (Caddy generates and trusts automatically)
    tls internal

    # Security headers (E9-01)
    header {
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.tile.openstreetmap.org; font-src 'self' data:; connect-src 'self' wss:; frame-ancestors 'none'"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
    }

    # SSE streaming — must be listed BEFORE handle /api/* (Caddy: first match wins).
    # flush_interval -1 disables response buffering so tokens stream to the browser.
    # No request_body limit here: query payloads are small JSON and SSE needs unbuffered response.
    handle /api/query/* {
        reverse_proxy host.docker.internal:8000 {
            flush_interval -1
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Agentic investigation SSE stream — flush_interval -1 required for real-time tool call streaming.
    handle /api/investigate/agentic {
        reverse_proxy host.docker.internal:8000 {
            flush_interval -1
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Investigations chat stream — flush_interval -1 required for token streaming.
    handle /api/investigations/chat-stream/* {
        reverse_proxy host.docker.internal:8000 {
            flush_interval -1
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # File upload endpoint — allow up to 100MB for evidence uploads.
    # Must appear BEFORE handle /api/* (Caddy: first match wins).
    handle /api/ingest/file {
        request_body {
            max_size 100MB
        }
        reverse_proxy host.docker.internal:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # API proxy — forward all other /api/* to FastAPI on host.
    # 10MB body limit blocks accidental oversized payloads before they reach Python.
    handle /api/* {
        request_body {
            max_size 10MB
        }
        reverse_proxy host.docker.internal:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            # Health check for upstream
            health_uri /health
            health_interval 15s
            health_timeout 5s
        }
    }

    handle /health* {
        reverse_proxy host.docker.internal:8000
    }

    # Dashboard SPA — served under /app/ subpath.
    # uri strip_prefix removes /app before resolving against /srv/dashboard,
    # so /app/assets/... maps to /srv/dashboard/assets/... correctly.
    handle /app/* {
        uri strip_prefix /app
        root * /srv/dashboard
        try_files {path} /index.html
        file_server
    }

    # Redirect root to dashboard
    handle / {
        redir /app/ temporary
    }

    # SPA fallback — proxy all unmatched paths to FastAPI.
    # FastAPI serves dashboard/dist/index.html for any non-API route,
    # so client-side paths like /detections, /overview, /events work directly.
    handle {
        reverse_proxy host.docker.internal:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
}
