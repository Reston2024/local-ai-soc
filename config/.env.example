DATA_DIR=data
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:14b
OLLAMA_EMBED_MODEL=mxbai-embed-large
LOG_LEVEL=INFO
HOST=127.0.0.1
PORT=8000

# API Authentication (optional — leave empty for localhost dev mode)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_TOKEN=

# Ollama model digest pinning (E6-03) — prevents silent model substitution attacks.
# Get current digest: curl http://localhost:11434/api/show -d '{"name":"qwen3:14b"}' | python -m json.tool
# Set the first 12+ characters of the sha256 digest field from the response.
# OLLAMA_MODEL_DIGEST=sha256:abc123...  # Expected digest prefix for OLLAMA_MODEL
# OLLAMA_EMBEDDING_DIGEST=sha256:...    # Expected digest prefix for OLLAMA_EMBED_MODEL
# OLLAMA_ENFORCE_DIGEST=False           # Set True in production to hard-fail on mismatch
